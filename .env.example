# === Betsala → Meta CAPI Backend ===

# Porta do servidor (Railway define automaticamente)
PORT=3000

# === Meta/Facebook CAPI Credentials ===
FACEBOOK_PIXEL_ID=961953570153415
FACEBOOK_ACCESS_TOKEN=seu_token_aqui
META_API_VERSION=v22.0

# Opcional: código de teste do Meta (usar somente em dev/test)
# META_TEST_EVENT_CODE=TEST12345

# === Postback Security ===
# Opcional: token de segurança validado nos postbacks
# POSTBACK_SECURITY_TOKEN=seu_token_aqui
# Opcional: lista de IPs permitidos separados por vírgula
# POSTBACK_ALLOWED_IPS=127.0.0.1,::1

# === Banco de Dados (PostgreSQL) ===
# Railway fornece a DATABASE_URL automaticamente
# Exemplo: postgresql://user:password@host:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/railway

# === Deduplicação ===
# Tempo em minutos para considerar um event_id como duplicado (default: 1440 = 24h)
# DEDUP_TTL_MINUTES=1440

# === Retry ===
# Número máximo de tentativas ao enviar para Meta CAPI (default: 3)
# RETRY_MAX_ATTEMPTS=3
# Delay base em ms (exponential backoff: 1s, 2s, 4s) (default: 1000)
# RETRY_BASE_DELAY_MS=1000

# === Batching ===
# Máximo de eventos por lote (default: 10)
# BATCH_MAX_SIZE=10
# Intervalo em ms para flush do lote (default: 5000)
# BATCH_FLUSH_INTERVAL_MS=5000

# === Logging ===
# LOG_LEVEL=trace|debug|info|warn|error (default: info)
# NODE_ENV=production|development