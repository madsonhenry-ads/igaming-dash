# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db>"

# Next.js
NEXT_PUBLIC_APP_URL="https://<your-project>.railway.app"
JWT_SECRET="<generate-a-random-64-char-string>"

# Email (Resend)
RESEND_API_KEY="re_<your-resend-api-key>"
RESEND_FROM_EMAIL="DASH-IGAMING <onboarding@resend.dev>"

# Admin Emails
ADMIN_EMAILS="admin@dashigaming.com"

# Environment
NODE_ENV="production"

# WhatsApp (Evolution API - optional)
# EVOLUTION_API_URL="http://localhost:8080"
# EVOLUTION_API_KEY="changeme"

# Facebook Ads (optional)
# FACEBOOK_ACCESS_TOKEN=""
# FACEBOOK_AD_ACCOUNT_ID=""
# FACEBOOK_PIXEL_ID=""